{
  "name": "atendebi",
  "version": "0.1.0",
  "private": true,
  "description": "AtendeBI monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev -w @atendebi/api\" \"npm run dev -w @atendebi/web\"",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:dev:detached": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "docker:logs": "docker compose -f docker-compose.yml -f docker-compose.dev.yml logs -f api web",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "docker:seed": "docker compose -f docker-compose.yml -f docker-compose.dev.yml exec api npm run db:seed",
    "build": "npm run build -ws",
    "lint": "npm run lint -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present",
    "db:generate": "npm run db:generate -w @atendebi/api",
    "db:migrate": "npm run db:migrate -w @atendebi/api",
    "db:seed": "npm run db:seed -w @atendebi/api",
    "db:studio": "npm run db:studio -w @atendebi/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
